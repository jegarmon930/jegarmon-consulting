# ─── ANTHROPIC (AI Consultant) ───────────────────────────────────────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── AIRTABLE (Lead Storage) ──────────────────────────────────────────────────
# Get your token at: https://airtable.com/create/tokens
# Base ID found in your Airtable base URL: airtable.com/YOUR_BASE_ID/...
AIRTABLE_TOKEN=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Leads

# ─── EMAIL NOTIFICATIONS (via Gmail) ─────────────────────────────────────────
# Use a Gmail account. Generate an App Password (not your regular password):
# Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=yourname@gmail.com
SMTP_PASS=your_gmail_app_password_here
NOTIFY_EMAIL=james@jegarmon.com

# ─── SMS NOTIFICATIONS (via Twilio) ──────────────────────────────────────────
# Sign up at: https://twilio.com (free trial available)
# Find these in your Twilio Console dashboard
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
NOTIFY_PHONE=+1xxxxxxxxxx
